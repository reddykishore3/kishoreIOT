graph = {
    'A': ['B', 'C'],
    'B': ['D', 'E'],
    'C': ['F'],
    'D': [],
    'E': ['F'],
    'F': []
}

visited = []

def dfs(graph, node):
    if node not in visited:
        visited.append(node)

        for neighbor in graph[node]:
            dfs(graph, neighbor)

dfs(graph, 'A')
print("DFS Traversal:", visited)

